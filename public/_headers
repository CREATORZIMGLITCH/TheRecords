# ─── SECURITY HEADERS FOR GITHUB PAGES ──────────────────────────────────────
# GitHub Pages serves static files through a CDN. These headers are served
# for every response from your site.
#
# HOW TO USE: Place this file in your /public folder. Vite will copy it
# to /dist on build, and GitHub Pages will serve it automatically.
# ─────────────────────────────────────────────────────────────────────────────

/*
  # ── Anti-clickjacking: nobody can embed this site in an iframe ──
  X-Frame-Options: DENY

  # ── Stops browsers from MIME-sniffing responses ──
  X-Content-Type-Options: nosniff

  # ── Only send origin (not full URL path) as referrer to other sites ──
  Referrer-Policy: strict-origin-when-cross-origin

  # ── Disable browser APIs this site doesn't need ──
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=(), usb=(), bluetooth=(), interest-cohort=()

  # ── Force HTTPS for 1 year, include subdomains ──
  # (Only applies if you use a custom domain with HTTPS)
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

  # ── Content Security Policy ──
  # Allows: your own origin, Google Fonts, GitHub API for comments,
  # GitHub avatars for comment profile pictures.
  # Blocks: everything else (inline eval, CDN scripts not listed, iframes, plugins)
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src https://fonts.gstatic.com; img-src 'self' data: https://avatars.githubusercontent.com; connect-src 'self' https://api.github.com; frame-ancestors 'none'; form-action 'self'; base-uri 'self'; object-src 'none';

  # ── Cross-Origin policies ──
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
